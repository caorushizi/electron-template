{
  "name": "@app/preload",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "types": "./dist/index.d.cts",
      "default": "./dist/index.cjs"
    },
    "./channels": {
      "types": "./dist/channels.d.ts",
      "import": "./dist/channels.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown"
  },
  "devDependencies": {
    "electron": "^41.0.0",
    "tsdown": "^0.15.9",
    "typescript": "^6.0.0"
  }
}
